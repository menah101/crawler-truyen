# =============================================================================
#  HƯỚNG DẪN CẤU HÌNH BIẾN MÔI TRƯỜNG — Crawler
#  Copy file này thành .env rồi điền giá trị thực
#
#  Crawler luôn chạy trên MÁY CÁ NHÂN (không phải RPi).
#  Nó đọc file này để biết kết nối tới đâu và dùng AI nào.
#
#  2 chế độ nhập dữ liệu (IMPORT_MODE trong config.py):
#    "local" — ghi thẳng vào SQLite trên máy này (máy = cùng nơi chứa DB)
#    "api"   — POST lên RPi qua HTTPS (RPi là server thật)
# =============================================================================


# -----------------------------------------------------------------------------
#  IMPORT MODE — Chọn nơi lưu dữ liệu sau khi crawl
# -----------------------------------------------------------------------------

# LOCAL (máy cá nhân, dev):
#   IMPORT_MODE=local
#   API_BASE_URL=http://localhost:3000   ← không dùng khi mode=local
#   API_SECRET=                          ← không dùng khi mode=local

# HOSTED (RPi chạy hongtrantruyen.net):
#   IMPORT_MODE=api
#   API_BASE_URL=https://hongtrantruyen.net
#   API_SECRET=<giá trị giống hệt IMPORT_SECRET trong .env.local trên RPi>

IMPORT_MODE=local
API_BASE_URL=http://localhost:3000
IMPORT_SECRET=


# -----------------------------------------------------------------------------
#  AI REWRITER — Viết lại nội dung chương
#  Chọn 1 provider trong config.py: REWRITE_PROVIDER = "..."
#  Chỉ cần điền key của provider bạn đang dùng.
# -----------------------------------------------------------------------------
OPENAI_API_KEY=

# Anthropic — claude-haiku (nhanh, rẻ)
#   Lấy key: https://console.anthropic.com → API Keys
# LOCAL  : key thật hoặc để trống nếu dùng ollama
# HOSTED : không cần (crawler không chạy trên RPi)
ANTHROPIC_API_KEY=

# Google Gemini — gemini-2.5-flash (miễn phí tier cao)
#   Lấy key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# DeepSeek — deepseek-chat (rẻ, chất lượng tốt)
#   Lấy key: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Groq — llama-3.3-70b (miễn phí, nhanh, giới hạn token/phút)
#   Lấy key: https://console.groq.com/keys
GROQ_API_KEY=

# Ollama — chạy model AI ngay trên máy cá nhân, MIỄN PHÍ
#   Cài: https://ollama.com → ollama pull qwen2.5:7b
#   Không cần key, chỉ cần Ollama đang chạy
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b


# -----------------------------------------------------------------------------
#  HUGGINGFACE — Tạo thumbnail tự động bằng FLUX.1-schnell
#   Lấy token: https://huggingface.co/settings/tokens (Read token)
# LOCAL  : token thật
# HOSTED : không cần (generate_thumbnails.py chạy trên máy cá nhân)
# -----------------------------------------------------------------------------
HF_API_TOKEN=

# Bật DOCX, chỉ định thư mục lưu và tên kênh
# Bật DOCX, chỉ định thư mục lưu và tên kênh
DOCX_EXPORT_ENABLED=true
DOCX_CHANNEL_NAME=Hồng Trần Truyện
SRT_EXPORT_ENABLED=true
SRT_OUTPUT_DIR=./docx_output       # cùng thư mục với DOCX (mặc định)
SRT_DURATION_PER_LINE=20           # giây mỗi dòng phụ đề
SRT_WORDS_PER_SECOND=0.25          # tốc độ đọc
